{
  "expo": {
    "name": "SYNTV Online",
    "slug": "syntv-online",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#050816",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.syntv.online"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050816"
      },
      "package": "com.syntv.online"
    },
    "plugins": [
      "expo-screen-orientation"
    ]
  }
}
