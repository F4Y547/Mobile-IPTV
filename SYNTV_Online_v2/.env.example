# ============================================================================
# SYNTV Online - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key (server-side ONLY - never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Encryption (used for Xtream passwords and sensitive data)
ENCRYPTION_SECRET=your-32-char-encryption-secret-minimum

# App
APP_URL=https://syntv.com
SUPPORT_EMAIL=support@syntv.com
SUPPORT_WHATSAPP=+8801XXXXXXXXX

# Optional: Sentry for crash reporting
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
